# Em CI/staging/prod, estas variáveis vêm do 1Password (op://costara-prod/web-env/*),
# resolvidas pelo load-secrets-action. Localmente, preencha este arquivo (.env, gitignored).
# Firebase
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# API
VITE_API_BASE_URL=http://localhost:3000/api
VITE_CUSTOMERS_PAGE_SIZE=20
VITE_PROJECTS_PAGE_SIZE=20
VITE_UNITS_PAGE_SIZE=20

# === AIOX Variables (added 2026-05-29) ===
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get your key at: https://exa.ai/
EXA_API_KEY=
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=
# Sentry (error tracking)
SENTRY_DSN=
# Railway (deployment)
RAILWAY_TOKEN=
# Vercel (deployment)
VERCEL_TOKEN=
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=5.2.9
